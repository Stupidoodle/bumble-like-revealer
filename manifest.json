{
  "manifest_version": 3,
  "name": "Bumble Like Revealer",
  "version": "0.2.0",
  "description": "Reveals who already liked you on Bumble by reading the data Bumble already sends to your browser.",
  "permissions": [
    "storage"
  ],
  "minimum_chrome_version": "111",
  "content_scripts": [
    {
      "matches": [
        "https://bumble.com/app*",
        "https://*.bumble.com/app*",
        "http://localhost:9000/*"
      ],
      "js": [
        "page.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://bumble.com/app*",
        "https://*.bumble.com/app*",
        "http://localhost:9000/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "bumble-like-revealer@stupidoodle",
      "strict_min_version": "128.0"
    }
  }
}
